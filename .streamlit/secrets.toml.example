# Copie este arquivo para .streamlit/secrets.toml e preencha com os valores reais.
# O secrets.toml NÃO deve ser commitado — está no .gitignore.
# No Streamlit Community Cloud, configure estes valores em:
#   App Settings → Secrets

# ── ActiveCampaign ────────────────────────────────────────────────
ACTIVECAMPAIGN_URL = "https://suaconta.api-us1.com"
ACTIVECAMPAIGN_API_KEY = "sua_chave_aqui"

# ── Google Sheets ─────────────────────────────────────────────────
SHEET_ID = "id_da_planilha_google"
SHEET_NAME = "Leads"

# ── Campos customizados ActiveCampaign ────────────────────────────
AC_FIELD_CATEGORIA = "76"
AC_FIELD_MODALIDADE = "77"
AC_FIELD_ESTADO = "72"

# ── Pipeline ActiveCampaign ───────────────────────────────────────
AC_PIPELINE_ID = "3"
AC_STAGE_INICIAL_ID = "11"

# ── Google Service Account (credentials.json como secrets) ────────
# Cole aqui o conteúdo do credentials.json como uma tabela TOML.
# Todos os campos são obrigatórios.
[gcp_service_account]
type = "service_account"
project_id = "seu-projeto"
private_key_id = "id_da_chave"
private_key = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email = "nome@seu-projeto.iam.gserviceaccount.com"
client_id = "123456789"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/nome%40seu-projeto.iam.gserviceaccount.com"
